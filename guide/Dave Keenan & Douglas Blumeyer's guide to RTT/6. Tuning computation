\end{matrix} \right]
\end{array}
\left( \scriptsize

\begin{array} {ccc}
M\mathrm{T}C\left(M\mathrm{T}C\right)^\mathsf{T} \\
\left[ \begin{matrix}
95.814 & {-269.394} \\
{-269.394} & 1098.637 \\
\end{matrix} \right]
\end{array}
\right)^{\normalsize -1}
</math>


Let's go ahead and invert that part:


<math>
\scriptsize
𝒈 = 
\begin{array} {ccc}
𝒋 \\
\left[ \begin{matrix}
1200.000 & 1901.955 & 2786.314 \\
\end{matrix} \right]
\end{array}

\begin{array} {ccc}
\mathrm{T}C \\
\left[ \begin{array} {c|c|c|c|c|c|c|c}
1.000 & 0.000 & {-2.585} & 7.170 & {-3.322} & 0.000 & {-8.644} & 4.907 \\
0.000 & 1.585 & 2.585 & {-3.585} & 0.000 & {-3.907} & 0.000 & 4.907 \\
0.000 & 0.000 & 0.000 & 0.000 & 3.322 & 3.907 & 4.322 & {-4.907} \\
\end{array} \right]
\end{array}

\begin{array} {ccc}
(M\mathrm{T}C)^\mathsf{T} \\
\left[ \begin{matrix}
1.000 & 0.000 \\ \hline
3.170 & {-4.755} \\ \hline
2.585 & {-7.755} \\  \hline
0.000 & 10.755 \\ \hline
6.644 & {-16.610} \\  \hline
3.907 & {-7.814} \\  \hline
4.322 & {-21.610} \\ \hline
0.000 & 9.814 \\
\end{matrix} \right]
\end{array}

\begin{array} {ccc}
(M\mathrm{T}C(M\mathrm{T}C)^\mathsf{T})^{-1} \\
\left[ \begin{matrix}
0.0336 & 0.00824 \\
