{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "d=$(git rev-parse --show-toplevel 2>/dev/null) && bash \"$d/.claude/hooks/git-rebase-guard.sh\" || true",
            "timeout": 10,
            "statusMessage": "git-rebase-guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "d=$(git rev-parse --show-toplevel 2>/dev/null) && bash \"$d/.claude/hooks/wip-checkpoint.sh\" || true",
            "timeout": 30,
            "statusMessage": "wip-checkpoint"
          }
        ]
      }
    ]
  }
}
