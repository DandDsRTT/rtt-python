#!/usr/bin/env python3
"""May ``main`` advance OLD..NEW without re-validating? — the MECHANICAL green check.

WHY THIS EXISTS
===============
The merge lock and render gate serialize *who* validates and merges, but nothing
ever proved that the green full render gate actually ran on the EXACT tree that
``git merge --ff-only`` lands. The protocol TRUSTED the landing agent to have run
``.venv/bin/python -m pytest -q`` green — so a change that landed on the *fast*
pass (``--ignore=.../test_web_render.py``), or whose own tree was already red,
could reach ``main`` with a red render gate. That actually happened
(``rtt/app/tooltips.py`` reworded a tooltip without updating the two render tests
that pin the wording).

This check makes the green evidence MECHANICAL instead of trusted. The render gate
(``tests/app/integration/conftest.py``) mints a **green token** — an empty file in
``$RTT_RENDER_GREEN_DIR`` (default ``/tmp/rtt-render-green.d``) named by the exact
git TREE it validated — only when a full ``pytest`` session that *collected the
render file* finishes green with a clean tracked worktree. A token therefore means
"the rendered output of this exact tree passed the full gate."

``bin/merge-guard-hook`` (a ``reference-transaction`` hook on the main checkout) and
``bin/land`` call this to decide an ff-merge of ``OLD`` (current ``main``) to
``NEW`` (the branch tip):

  SAFE iff
    * OLD..NEW is render-orthogonal (the change can't affect rendered output, so no
      gate was ever needed — the same judgment ``bin/merge-safe-check`` mechanizes),
      OR
    * some green token validated a tree that is render-equivalent to NEW's tree
      (token tree == NEW tree, or they differ only in render-irrelevant files — so a
      prior green run still validates NEW's rendered output).
  UNSAFE otherwise: a render-relevant tree with no green token is precisely the
  "red web change reaches main" bug.

Usage::

    bin/merge-green-check <old> <new>     # old = current main, new = branch tip to land

Exit: 0 SAFE · 1 UNSAFE · 2 ERROR (could not evaluate). Callers guarding the live
checkout should fail OPEN on 2 (the hook does) so a transient git error never blocks
the user's own main. ``RTT_FFMERGE_GUARD_OFF=1`` forces SAFE (human escape hatch).

Pure stdlib, Python 3.7+ (must run under system ``python3`` in a git hook — no
dependency on the repo ``.venv``).
"""

import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _render_relevance as _rr

_GREEN_DIR = os.environ.get("RTT_RENDER_GREEN_DIR", "/tmp/rtt-render-green.d")


def _git(*args):
    return subprocess.run(["git", *args], capture_output=True, text=True)


def _tree(ref):
    r = _git("rev-parse", "%s^{tree}" % ref)
    return r.stdout.strip() if r.returncode == 0 else None


def _delta_relevant(a, b):
    """Render-relevant files in a..b, or None if the diff itself failed."""
    r = _git("diff", "--name-only", "%s..%s" % (a, b))
    if r.returncode != 0:
        r = _git("diff", "--name-only", a, b)
    if r.returncode != 0:
        return None
    return _rr.relevant(r.stdout.splitlines())


def _green_trees():
    try:
        names = os.listdir(_GREEN_DIR)
    except OSError:
        return []
    out = []
    for n in names:
        if len(n) == 40 and all(c in "0123456789abcdef" for c in n):
            out.append(n)
    return out


def main(argv):
    if os.environ.get("RTT_FFMERGE_GUARD_OFF") == "1":
        print("[merge-green] SAFE: RTT_FFMERGE_GUARD_OFF=1 (human override)")
        return 0
    if len(argv) < 2:
        print("usage: bin/merge-green-check <old> <new>", file=sys.stderr)
        return 2

    old, new = argv[0], argv[1]
    new_tree = _tree(new)
    if new_tree is None:
        print("[merge-green] error: cannot resolve tree of %s" % new, file=sys.stderr)
        return 2

    own = _delta_relevant(old, new)
    if own is None:
        print("[merge-green] error: cannot diff %s..%s" % (old, new), file=sys.stderr)
        return 2
    if not own:
        print("[merge-green] SAFE: %s..%s is render-orthogonal — no render gate needed."
              % (old[:12], new[:12]))
        return 0

    for g in _green_trees():
        d = _delta_relevant(g, new_tree)
        if d == []:
            why = "exact tree" if g == new_tree else "render-equivalent tree"
            print("[merge-green] SAFE: green render-gate token for %s (%s %s)."
                  % (new_tree[:12], why, g[:12]))
            return 0

    print("[merge-green] UNSAFE: %d render-relevant file(s) in %s..%s and NO green "
          "render-gate token validates tree %s:"
          % (len(own), old[:12], new[:12], new_tree[:12]), file=sys.stderr)
    for p in own[:20]:
        print("    ! %s" % p, file=sys.stderr)
    print("[merge-green] Run the FULL gate on this exact tree "
          "(.venv/bin/python -m pytest -q) — it mints the token — or land via bin/land.",
          file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
