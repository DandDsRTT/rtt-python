#!/usr/bin/env python3
"""Install the ``reference-transaction`` merge guard into the shared git hooks dir.

The installed hook is a tiny POSIX-sh **shim** that locates the repo and execs
``bin/merge-guard-hook`` (whose logic stays versioned in the tree, so updating the
guard never requires reinstalling). It lives in the *common* git dir's ``hooks/``,
which every worktree — including the main checkout that runs the landing
``git merge --ff-only`` — shares, so one install protects every land.

Idempotent. Safe-by-default: refuses to clobber a pre-existing hook that is NOT ours
unless ``--force`` (then it backs the old one up to ``<hook>.pre-rtt-merge-guard``).

Usage::

    bin/install-merge-guard-hook            # install / update (idempotent)
    bin/install-merge-guard-hook --force    # overwrite a foreign existing hook
    bin/install-merge-guard-hook --check    # exit 0 iff our hook is installed & current

Exit: 0 ok/installed/current · 1 a foreign hook is in the way (use --force) ·
2 environment error (not a git repo, …) · 3 (--check) not installed / stale.
"""

import os
import stat
import subprocess
import sys

_MARK = "rtt-merge-guard v1"
_SHIM = """#!/bin/sh
# %s — installed by bin/install-merge-guard-hook; do not edit (logic is in bin/merge-guard-hook).
# Refuses a render-relevant fast-forward of refs/heads/main with no green render-gate token.
# Fast-paths everything that ISN'T a prepared-phase main update so it adds ~no cost to the
# thousands of feature-branch ref updates parallel agents make.
[ "$1" = "prepared" ] || exit 0
input=$(cat)
case "$input" in
  *refs/heads/main*|*refs/heads/master*) ;;
  *) exit 0 ;;
esac
dir=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -n "$dir" ] && [ -f "$dir/bin/merge-guard-hook" ] || exit 0
printf '%%s\\n' "$input" | /usr/bin/env python3 "$dir/bin/merge-guard-hook" "$@"
exit $?
""" % _MARK


def _hooks_path():
    r = subprocess.run(["git", "rev-parse", "--git-common-dir"],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return None
    common = os.path.abspath(r.stdout.strip())
    return os.path.join(common, "hooks", "reference-transaction")


def _make_executable(path):
    st = os.stat(path)
    os.chmod(path, st.st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)


def main(argv):
    check_only = "--check" in argv
    force = "--force" in argv

    target = _hooks_path()
    if target is None:
        sys.stderr.write("[install-merge-guard] not a git repo (git rev-parse failed)\n")
        return 2

    existing = None
    if os.path.exists(target):
        try:
            with open(target) as f:
                existing = f.read()
        except OSError:
            existing = None

    if check_only:
        ok = existing is not None and existing == _SHIM
        if ok:
            print("[install-merge-guard] installed and current: %s" % target)
            return 0
        if existing is not None and _MARK in existing:
            print("[install-merge-guard] STALE (older version): %s" % target, file=sys.stderr)
        else:
            print("[install-merge-guard] NOT installed: %s" % target, file=sys.stderr)
        return 3

    if existing == _SHIM:
        print("[install-merge-guard] already installed and current: %s" % target)
        return 0

    if existing is not None and _MARK not in existing:
        if not force:
            sys.stderr.write(
                "[install-merge-guard] a non-rtt reference-transaction hook already exists:\n"
                "    %s\n"
                "Re-run with --force to back it up and replace it.\n" % target)
            return 1
        backup = target + ".pre-rtt-merge-guard"
        try:
            os.replace(target, backup)
            print("[install-merge-guard] backed up existing hook to %s" % backup)
        except OSError as e:
            sys.stderr.write("[install-merge-guard] could not back up existing hook: %s\n" % e)
            return 2

    os.makedirs(os.path.dirname(target), exist_ok=True)
    tmp = "%s.tmp-%d" % (target, os.getpid())
    with open(tmp, "w") as f:
        f.write(_SHIM)
    os.replace(tmp, target)
    _make_executable(target)
    print("[install-merge-guard] installed: %s" % target)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
