#!/usr/bin/env python3
"""Optimistic-validate / short-lock landing — hold the merge lock for SECONDS, not the
whole ~9-min render gate.

WHY THIS EXISTS
===============
``bin/with-merge-lock`` (see its header) makes landing CORRECT by serializing the whole
``rebase → render gate → ff-merge`` critical section: only the lock-holder validates and
merges, so you always land the EXACT state you validated. But it holds the lock across
the ~9-minute render gate, so EVERY merge — even a docs- or ``bin/``-only change that
cannot affect rendered output — queues behind the slowest render run. Under a dozen
parallel agents the lock queue is minutes deep by construction, and orthogonal changes
that need no gate at all wait just as long as a hot-file ``rtt/app/`` change.

This script shrinks the lock-held section to the ff-merge alone:

  1. **Validate WITHOUT the lock.** Rebase onto ``main`` and run the render gate (still
     serialized by the render-gate semaphore in ``tests/app/integration/conftest.py`` —
     CPU is never oversubscribed). If THIS change is itself render-orthogonal
     (``bin/merge-safe-check`` on our own diff), skip the gate entirely.
  2. **Take the lock only for the ff-merge.** While holding it (so ``main`` is frozen),
     decide with ``merge-safe-check`` whether ``main`` moved in a render-RELEVANT way
     since the base we validated:
       * not moved, or moved only orthogonally → rebase (fast-forward over the orthogonal
         commits, no re-gate) and ``git merge --ff-only``. Seconds.
       * moved render-relevant → our validation is now stale: release and loop back to
         step 1 (re-validate LOCKLESS). The lock is never held across a gate.
  3. **Fallback for sustained collisions.** After ``--max-optimistic`` lockless rounds
     keep getting outrun by render-relevant lands, fall back to the proven legacy flow
     (``with-merge-lock bash -c 'rebase; gate; ff-merge'``) which HOLDS the lock across
     one final gate — guaranteeing forward progress. That under-lock gate runs through the
     render semaphore normally and is auto-granted a PRIORITY slot (the conftest detects
     the held merge lock), so it never idles the lock behind speculative runs and never
     needs the old manual ``RTT_RENDER_GATE_NOLOCK=1``.

CORRECTNESS is preserved end to end: we only ever ``ff-merge`` a state whose rendered
output we actually validated, because the under-lock ``merge-safe-check`` proves the
frozen ``main`` is render-equivalent to our validated base (or our own change is
orthogonal, so no gate was needed). ``git merge --ff-only`` remains the atomic ref-CAS
backstop, and FIFO fairness lives entirely in ``with-merge-lock`` — this script only
sequences its ``acquire``/``release`` around a much shorter critical section.

Usage (run from your worktree, on your ``claude/<name>`` branch)::

    bin/land                                  # gate = .venv/bin/python -m pytest -q
    bin/land -- <gate command...>             # custom gate (interpreter, flags, …)
    bin/land --max-optimistic 4 -- <gate...>

Exit status: 0 landed · 1 gate failed / gave up · 2 rebase conflict (resolve, re-run) ·
3 lock error · 4 usage / environment error.
"""

import os
import subprocess
import sys

_HERE = os.path.dirname(os.path.abspath(__file__))
_WITH_LOCK = os.path.join(_HERE, "with-merge-lock")
_SAFE_CHECK = os.path.join(_HERE, "merge-safe-check")
_INSTALL_HOOK = os.path.join(_HERE, "install-merge-guard-hook")
_PY = sys.executable


def _log(msg):
    sys.stderr.write("[land] %s\n" % msg)
    sys.stderr.flush()


def _git(*args, check=False, cwd=None):
    r = subprocess.run(["git", *args], capture_output=True, text=True, cwd=cwd)
    if check and r.returncode != 0:
        raise RuntimeError("git %s failed: %s" % (" ".join(args), r.stderr.strip()))
    return r


def _main_checkout():
    """Absolute path of the worktree that has ``main`` checked out (the live app the
    user runs; the only checkout we are allowed to ff-merge INTO)."""
    r = _git("worktree", "list", "--porcelain")
    if r.returncode != 0:
        return None
    path = None
    for line in r.stdout.splitlines():
        if line.startswith("worktree "):
            path = line[len("worktree "):]
        elif line.strip() in ("branch refs/heads/main", "branch refs/heads/master"):
            return path
    return None


def _current_branch():
    r = _git("rev-parse", "--abbrev-ref", "HEAD")
    return r.stdout.strip() if r.returncode == 0 else None


def _rev(ref, cwd=None):
    r = _git("rev-parse", ref, cwd=cwd)
    return r.stdout.strip() if r.returncode == 0 else None


def _safe(base, tip):
    """True iff base..tip is render-orthogonal (merge-safe-check exit 0)."""
    r = subprocess.run([_PY, _SAFE_CHECK, base, tip], capture_output=True, text=True)
    return r.returncode == 0


def _diff_is_orthogonal(base):
    """True iff OUR change (base..HEAD) touches no render-relevant file — then no gate
    is needed at all, ever, regardless of how main moves."""
    return _safe(base, "HEAD")


def _rebase_onto_main():
    """Rebase the current branch onto ``main``. Returns 'ok', 'noop', or 'conflict'."""
    r = _git("rebase", "main")
    if r.returncode == 0:
        return "ok"
    _git("rebase", "--abort")
    return "conflict"


def _run_gate(gate_cmd):
    _log("validating (lockless): %s" % " ".join(gate_cmd))
    return subprocess.run(gate_cmd).returncode == 0


def _lock(*args):
    return subprocess.run([_PY, _WITH_LOCK, *args]).returncode


def _ff_merge(main_checkout, branch):
    r = _git("-C", main_checkout, "merge", "--ff-only", branch)
    if r.returncode != 0:
        _log("ff-merge rejected: %s" % r.stderr.strip())
    return r.returncode == 0


def _legacy_fallback(main_checkout, branch, gate_cmd):
    """Proven path: hold the lock across one rebase+gate+ff-merge, guaranteeing progress
    when optimistic rounds keep losing to render-relevant churn. The under-lock gate runs
    through the render semaphore normally — it auto-detects that we hold the merge lock and
    takes a PRIORITY slot (see tests/app/integration/conftest.py), so it never idles the
    lock queued behind speculative runs AND stays visible so non-holders don't pile on. This
    replaces the old blunt ``RTT_RENDER_GATE_NOLOCK=1`` (which hid the run from the semaphore
    entirely, inviting oversubscription)."""
    _log("optimistic rounds exhausted; falling back to held-lock land (one final gate)")
    script = (
        "set -e; git rebase main; "
        "%s; "
        "git -C %s merge --ff-only %s"
        % (" ".join(gate_cmd), _q(main_checkout), _q(branch))
    )
    return subprocess.run([_PY, _WITH_LOCK, "bash", "-c", script]).returncode


def _q(s):
    return "'" + s.replace("'", "'\\''") + "'"


def _land_once(main_checkout, branch, gate_cmd):
    """One optimistic round. Returns 'landed', 'retry', or 'conflict'."""
    if _rebase_onto_main() == "conflict":
        return "conflict"
    # After the rebase, merge-base(main, HEAD) == the current main tip — so THIS is the
    # exact base our gate run validates, and what merge-safe-check compares against.
    main_at_validate = _rev("main")

    my_orthogonal = _diff_is_orthogonal(main_at_validate)
    if my_orthogonal:
        _log("this change is render-orthogonal — skipping the gate")
    else:
        if not _run_gate(gate_cmd):
            _log("gate FAILED — fix and re-run; not landing")
            return "gate-failed"

    if _lock("acquire") != 0:
        return "lock-failed"
    try:
        locked_main = _rev("main")
        if my_orthogonal or locked_main == main_at_validate or _safe(main_at_validate, locked_main):
            if _rebase_onto_main() == "conflict":
                return "conflict"
            if _ff_merge(main_checkout, branch):
                why = ("orthogonal change" if my_orthogonal
                       else "main unmoved" if locked_main == main_at_validate
                       else "main moved orthogonally")
                _log("LANDED (%s) — main now %s" % (why, _rev("main", cwd=main_checkout)[:12]))
                return "landed"
            return "retry"
        _log("main moved render-relevant during validation — re-validating lockless")
        return "retry"
    finally:
        _lock("release")


def main(argv):
    max_optimistic = 3
    gate_cmd = None
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--max-optimistic":
            i += 1
            try:
                max_optimistic = int(argv[i])
            except (IndexError, ValueError):
                _log("--max-optimistic needs an integer")
                return 4
        elif a == "--":
            gate_cmd = argv[i + 1:]
            break
        else:
            _log("unknown arg %r (did you mean to put the gate after --?)" % a)
            return 4
        i += 1
    if not gate_cmd:
        gate_cmd = [".venv/bin/python", "-m", "pytest", "-q"]

    subprocess.run([_PY, _INSTALL_HOOK])

    main_checkout = _main_checkout()
    branch = _current_branch()
    if not main_checkout:
        _log("could not locate the main checkout (git worktree with main) — aborting")
        return 4
    if not branch or branch in ("main", "master"):
        _log("refusing to land: not on a feature branch (on %r)" % branch)
        return 4
    if _rev("main") is None:
        _log("no local 'main' ref to rebase onto — aborting")
        return 4

    for attempt in range(1, max_optimistic + 1):
        _log("optimistic land, round %d/%d (branch %s → %s)"
             % (attempt, max_optimistic, branch, main_checkout))
        outcome = _land_once(main_checkout, branch, gate_cmd)
        if outcome == "landed":
            return 0
        if outcome == "gate-failed":
            return 1
        if outcome == "conflict":
            _log("rebase conflict — resolve in your worktree, then re-run bin/land")
            return 2
        if outcome == "lock-failed":
            _log("could not acquire/hold the merge lock — aborting")
            return 3
        # outcome == "retry": main moved render-relevant; loop and re-validate lockless

    rc = _legacy_fallback(main_checkout, branch, gate_cmd)
    return 0 if rc == 0 else 1


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
