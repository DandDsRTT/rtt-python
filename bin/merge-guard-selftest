#!/usr/bin/env python3
"""Isolated self-test for the mechanical green-gate ff-merge guard.

Proves — in a throwaway git repo, never touching the real
``/tmp/rtt-render-green.d/`` or the live main checkout — that the
``reference-transaction`` hook installed by ``bin/install-merge-guard-hook``
REJECTS an ungated render-relevant fast-forward of ``main`` and ALLOWS exactly the
legitimate landing paths. This is the guard against "a red web change reached main";
run it by hand or in CI::

    /usr/bin/python3 bin/merge-guard-selftest          # pure stdlib

Exits 0 iff every scenario passes; prints PASS/FAIL per scenario.

Scenarios (each does a real ``git merge --ff-only`` of a feature branch into main):
  1. render-relevant change, NO green token        → ff-merge REJECTED
  2. render-relevant change, matching green token  → ff-merge ALLOWED
  3. render-relevant change, token for a STALE tree→ ff-merge REJECTED
  4. render-orthogonal change (docs only), no token→ ff-merge ALLOWED
  5. green token for a render-EQUIVALENT tree       → ff-merge ALLOWED (orthogonal drift)
  6. RTT_FFMERGE_GUARD_OFF=1 overrides a rejection  → ff-merge ALLOWED
  7. a rewind of main (non-fast-forward) is never guarded → ALLOWED
"""

import os
import shutil
import subprocess
import sys
import tempfile

_BIN = os.path.dirname(os.path.abspath(__file__))
_SCRIPTS = ("_render_relevance.py", "merge-safe-check", "merge-green-check",
            "merge-guard-hook", "install-merge-guard-hook")

_results = []


def _record(name, ok, detail=""):
    _results.append((name, ok, detail))
    print("  %s  %s%s" % ("PASS" if ok else "FAIL", name, (" — " + detail) if detail else ""))


def _run(args, cwd, env=None, check=False):
    e = dict(os.environ)
    if env:
        e.update(env)
    r = subprocess.run(args, cwd=cwd, env=e, capture_output=True, text=True)
    if check and r.returncode != 0:
        raise RuntimeError("cmd %s failed: %s" % (args, r.stderr.strip()))
    return r


def _git(repo, *args, env=None, check=False):
    return _run(["git", *args], cwd=repo, env=env, check=check)


def _commit_file(repo, path, content, msg, env):
    full = os.path.join(repo, path)
    os.makedirs(os.path.dirname(full), exist_ok=True)
    with open(full, "w") as f:
        f.write(content)
    _git(repo, "add", "-A", env=env, check=True)
    _git(repo, "commit", "-q", "-m", msg, env=env, check=True)
    return _git(repo, "rev-parse", "HEAD", env=env, check=True).stdout.strip()


def _tree_of(repo, ref, env):
    return _git(repo, "rev-parse", "%s^{tree}" % ref, env=env, check=True).stdout.strip()


def _setup(tmp):
    repo = tempfile.mkdtemp(prefix="repo-", dir=tmp)
    os.makedirs(os.path.join(repo, "bin"))
    for s in _SCRIPTS:
        shutil.copy2(os.path.join(_BIN, s), os.path.join(repo, "bin", s))
        os.chmod(os.path.join(repo, "bin", s), 0o755)
    env = {
        "GIT_AUTHOR_NAME": "t", "GIT_AUTHOR_EMAIL": "t@t",
        "GIT_COMMITTER_NAME": "t", "GIT_COMMITTER_EMAIL": "t@t",
        "RTT_RENDER_GREEN_DIR": os.path.join(tmp, "green.d"),
    }
    _git(repo, "init", "-q", "-b", "main", env=env, check=True)
    _commit_file(repo, "rtt/app/x.py", "v = 1\n", "base", env)
    _commit_file(repo, "README.md", "hello\n", "readme", env)
    _run([sys.executable, os.path.join(repo, "bin", "install-merge-guard-hook")],
         cwd=repo, env=env, check=True)
    return repo, env


def _branch_from_main(repo, name, env):
    _git(repo, "checkout", "-q", "-b", name, "main", env=env, check=True)


def _back_to_main(repo, env):
    _git(repo, "checkout", "-q", "main", env=env, check=True)


def _ff(repo, branch, env, extra_env=None):
    e = dict(env)
    if extra_env:
        e.update(extra_env)
    return _git(repo, "merge", "--ff-only", branch, env=e)


def _write_token(env, tree):
    d = env["RTT_RENDER_GREEN_DIR"]
    os.makedirs(d, exist_ok=True)
    with open(os.path.join(d, tree), "w") as f:
        f.write("{}")


def _clear_tokens(env):
    d = env["RTT_RENDER_GREEN_DIR"]
    if os.path.isdir(d):
        shutil.rmtree(d)


def scenario_1_relevant_no_token(repo, env):
    _branch_from_main(repo, "f1", env)
    _commit_file(repo, "rtt/app/x.py", "v = 2\n", "render-relevant change", env)
    _back_to_main(repo, env)
    r = _ff(repo, "f1", env)
    _record("relevant change, no token → REJECTED", r.returncode != 0,
            "merge unexpectedly succeeded" if r.returncode == 0 else "")


def scenario_2_relevant_with_token(repo, env):
    _branch_from_main(repo, "f2", env)
    _commit_file(repo, "rtt/app/x.py", "v = 3\n", "render-relevant change", env)
    tip_tree = _tree_of(repo, "f2", env)
    _back_to_main(repo, env)
    _write_token(env, tip_tree)
    r = _ff(repo, "f2", env)
    _record("relevant change, matching token → ALLOWED", r.returncode == 0,
            r.stderr.strip() if r.returncode != 0 else "")


def scenario_3_stale_token(repo, env):
    _branch_from_main(repo, "f3", env)
    _commit_file(repo, "rtt/app/x.py", "v = 4\n", "render-relevant change", env)
    _back_to_main(repo, env)
    _write_token(env, "0" * 40)  # token for a tree that isn't ours
    r = _ff(repo, "f3", env)
    _record("relevant change, stale token → REJECTED", r.returncode != 0,
            "merge unexpectedly succeeded" if r.returncode == 0 else "")


def scenario_4_orthogonal(repo, env):
    _branch_from_main(repo, "f4", env)
    _commit_file(repo, "README.md", "docs change\n", "docs only", env)
    _back_to_main(repo, env)
    r = _ff(repo, "f4", env)
    _record("orthogonal change, no token → ALLOWED", r.returncode == 0,
            r.stderr.strip() if r.returncode != 0 else "")


def scenario_5_equivalent_tree(repo, env):
    # Token validated tree T (a render-relevant change). main then drifts ORTHOGONALLY
    # and the branch is rebased on top, landing tree T' that differs from T only in
    # docs — the green run for T still validates T'.
    _branch_from_main(repo, "f5", env)
    _commit_file(repo, "rtt/app/x.py", "v = 5\n", "render-relevant change", env)
    validated_tree = _tree_of(repo, "f5", env)
    _back_to_main(repo, env)
    _commit_file(repo, "guide/notes.md", "orthogonal main drift\n", "orthogonal drift", env)
    _git(repo, "rebase", "main", "f5", env=env, check=True)
    _back_to_main(repo, env)
    _write_token(env, validated_tree)  # token only for the PRE-drift tree
    r = _ff(repo, "f5", env)
    _record("render-equivalent tree token → ALLOWED", r.returncode == 0,
            r.stderr.strip() if r.returncode != 0 else "")


def scenario_6_override(repo, env):
    _branch_from_main(repo, "f6", env)
    _commit_file(repo, "rtt/app/x.py", "v = 6\n", "render-relevant change", env)
    _back_to_main(repo, env)
    r = _ff(repo, "f6", env, extra_env={"RTT_FFMERGE_GUARD_OFF": "1"})
    _record("override forces ALLOWED", r.returncode == 0,
            r.stderr.strip() if r.returncode != 0 else "")


def scenario_7_rewind(repo, env):
    # A non-fast-forward move of main (rewind to an older commit) is a deliberate human
    # op, never a land — the guard must not block it even with no token.
    head = _git(repo, "rev-parse", "main", env=env, check=True).stdout.strip()
    prev = _git(repo, "rev-parse", "main~1", env=env, check=True).stdout.strip()
    r = _git(repo, "update-ref", "refs/heads/main", prev, head, env=env)
    _record("rewind of main (non-ff) → ALLOWED", r.returncode == 0,
            r.stderr.strip() if r.returncode != 0 else "")


def main():
    tmp = tempfile.mkdtemp(prefix="rtt-merge-guard-selftest-")
    scenarios = (
        scenario_1_relevant_no_token,
        scenario_2_relevant_with_token,
        scenario_3_stale_token,
        scenario_4_orthogonal,
        scenario_5_equivalent_tree,
        scenario_6_override,
        scenario_7_rewind,
    )
    try:
        print("merge-guard self-test (fresh repo per scenario in %s)" % tmp)
        for s in scenarios:
            repo, env = _setup(tmp)  # each scenario gets a pristine repo + green dir
            s(repo, env)
    finally:
        shutil.rmtree(tmp, ignore_errors=True)

    passed = sum(1 for _, ok, _ in _results if ok)
    print("\n%d/%d scenarios passed" % (passed, len(_results)))
    return 0 if passed == len(_results) else 1


if __name__ == "__main__":
    sys.exit(main())
