#!/usr/bin/env python3
"""Isolated self-test for ``bin/land`` (the optimistic short-lock landing flow).

Builds a throwaway git repo (a ``main`` checkout + a feature worktree) per scenario, with
a private merge-gate dir and tiny lock timings, so it never touches the real
``/tmp/rtt-merge-gate.d`` or the live ``main``. Gates are trivial shell scripts; "another
agent landing during my gate" is simulated by a gate that commits onto ``main`` on its
first run. Spawns real lock daemons, so — like ``with-merge-lock-selftest`` — it is NOT a
pytest test; run it by hand or in CI::

    /usr/bin/python3 bin/land-selftest

Exits 0 iff every scenario passes.

Scenarios:
  1. happy path — render-relevant change, gate passes → ff-merge lands it
  2. orthogonal change — bin/-only diff SKIPS the gate entirely and still lands
  3. orthogonal collision — main moves orthogonally DURING the gate → rebase + ff-merge,
     no re-gate (gate runs exactly once); both changes end up on main
  4. render-relevant collision — main moves in rtt/ DURING the gate → stale validation,
     re-validate LOCKLESS and land on the next round (gate runs twice)
"""

import os
import subprocess
import sys
import tempfile
import time

HERE = os.path.dirname(os.path.abspath(__file__))
LAND = os.path.join(HERE, "land")
PY = sys.executable
_results = []


def record(name, ok, detail=""):
    _results.append((name, ok))
    print("%s  %s%s" % ("PASS" if ok else "FAIL", name, ("  — " + detail) if detail else ""))


def git(cwd, *args, check=True):
    r = subprocess.run(["git", *args], cwd=cwd, capture_output=True, text=True)
    if check and r.returncode != 0:
        raise RuntimeError("git %s @ %s failed: %s" % (" ".join(args), cwd, r.stderr.strip()))
    return r


def write(path, text):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        f.write(text)


def make_repo():
    """A main checkout with an initial commit; returns (repo, gate_dir)."""
    repo = tempfile.mkdtemp(prefix="rtt-land-repo.")
    gate_dir = tempfile.mkdtemp(prefix="rtt-land-gate.")
    git(repo, "init", "-q", "-b", "main")
    git(repo, "config", "user.email", "t@t")
    git(repo, "config", "user.name", "t")
    write(os.path.join(repo, "rtt", "core.py"), "x = 1\n")
    write(os.path.join(repo, "README.md"), "readme\n")
    git(repo, "add", "-A")
    git(repo, "commit", "-q", "-m", "init")
    return repo, gate_dir


def add_worktree(repo, branch="claude/test"):
    wt = tempfile.mkdtemp(prefix="rtt-land-wt.")
    os.rmdir(wt)  # git worktree add wants a non-existent path
    git(repo, "worktree", "add", "-q", "-b", branch, wt, "main")
    git(wt, "config", "user.email", "t@t")
    git(wt, "config", "user.name", "t")
    return wt


def env(gate_dir, lock_id):
    e = dict(os.environ)
    e["RTT_MERGE_GATE_DIR"] = gate_dir
    e["RTT_MERGE_LOCK_ID"] = lock_id
    e["RTT_MERGE_GATE_LEASE"] = "6"
    e["RTT_MERGE_GATE_GRACE"] = "1"
    e["RTT_MERGE_GATE_RENEW"] = "1"
    e["RTT_MERGE_GATE_GAP"] = "120"
    e["RTT_MERGE_GATE_TTL"] = "120"
    e["RTT_MERGE_GATE_READY"] = "10"
    return e


def gate_script(repo, body=""):
    """Write a gate shell script; returns its path. `body` runs before exit 0; it may use
    $REPO (the main checkout) to simulate a concurrent land, and $MARK to count runs."""
    p = tempfile.mktemp(prefix="rtt-land-gate.sh.")
    write(p, "#!/bin/bash\nset -e\nREPO=%r\nMARK=%r\necho run >> \"$MARK\"\n%s\nexit 0\n"
          % (repo, p + ".runs", body))
    os.chmod(p, 0o755)
    return p


def run_land(wt, gate_dir, lock_id, gate_path, extra=()):
    return subprocess.run([PY, LAND, *extra, "--", "bash", gate_path],
                          cwd=wt, env=env(gate_dir, lock_id),
                          capture_output=True, text=True, timeout=120)


def run_count(gate_path):
    try:
        with open(gate_path + ".runs") as f:
            return sum(1 for _ in f)
    except OSError:
        return 0


def main_files(repo):
    r = git(repo, "ls-tree", "-r", "--name-only", "main")
    return set(r.stdout.split())


def cleanup(repo, gate_dir, wt=None):
    for d in (repo, gate_dir, wt):
        if d:
            subprocess.run(["rm", "-rf", d])


# --------------------------------------------------------------------------- #
def t_happy():
    repo, gate_dir = make_repo()
    wt = add_worktree(repo)
    try:
        write(os.path.join(wt, "rtt", "feature.py"), "y = 2\n")
        git(wt, "add", "-A"); git(wt, "commit", "-q", "-m", "feat")
        g = gate_script(repo)  # trivial pass
        r = run_land(wt, gate_dir, "happy", g)
        ok = r.returncode == 0 and "rtt/feature.py" in main_files(repo)
        ok = ok and run_count(g) == 1  # render-relevant change → gate ran once
        record("happy path (relevant change, gate passes)", ok,
               "rc=%d gate_runs=%d" % (r.returncode, run_count(g)))
    finally:
        cleanup(repo, gate_dir, wt)


def t_orthogonal_skip():
    repo, gate_dir = make_repo()
    wt = add_worktree(repo)
    try:
        write(os.path.join(wt, "bin", "helper"), "echo hi\n")
        git(wt, "add", "-A"); git(wt, "commit", "-q", "-m", "tool")
        g = gate_script(repo)
        r = run_land(wt, gate_dir, "ortho", g)
        ok = (r.returncode == 0 and "bin/helper" in main_files(repo)
              and run_count(g) == 0)  # orthogonal → gate SKIPPED
        record("orthogonal change skips gate", ok,
               "rc=%d gate_runs=%d (want 0)" % (r.returncode, run_count(g)))
    finally:
        cleanup(repo, gate_dir, wt)


def t_orthogonal_collision():
    repo, gate_dir = make_repo()
    wt = add_worktree(repo)
    try:
        write(os.path.join(wt, "rtt", "feature.py"), "y = 2\n")
        git(wt, "add", "-A"); git(wt, "commit", "-q", "-m", "feat")
        # During the (first) gate, another agent lands an ORTHOGONAL commit on main.
        body = ('if [ ! -f "$MARK.done" ]; then touch "$MARK.done"; '
                'echo notes > "$REPO/NOTES.md"; '
                'git -C "$REPO" add -A; git -C "$REPO" commit -q -m concurrent-ortho; fi')
        g = gate_script(repo, body)
        r = run_land(wt, gate_dir, "ortho-col", g)
        files = main_files(repo)
        ok = (r.returncode == 0 and "rtt/feature.py" in files and "NOTES.md" in files
              and run_count(g) == 1)  # orthogonal move → NO re-gate
        record("orthogonal collision: rebase + ff-merge, no re-gate", ok,
               "rc=%d gate_runs=%d (want 1) files_ok=%s"
               % (r.returncode, run_count(g), "rtt/feature.py" in files and "NOTES.md" in files))
    finally:
        cleanup(repo, gate_dir, wt)


def t_relevant_collision():
    repo, gate_dir = make_repo()
    wt = add_worktree(repo)
    try:
        write(os.path.join(wt, "rtt", "feature.py"), "y = 2\n")
        git(wt, "add", "-A"); git(wt, "commit", "-q", "-m", "feat")
        # During the FIRST gate only, another agent lands a RENDER-RELEVANT commit on main.
        body = ('if [ ! -f "$MARK.done" ]; then touch "$MARK.done"; '
                'echo "z = 9" > "$REPO/rtt/other.py"; '
                'git -C "$REPO" add -A; git -C "$REPO" commit -q -m concurrent-relevant; fi')
        g = gate_script(repo, body)
        r = run_land(wt, gate_dir, "rel-col", g)
        files = main_files(repo)
        ok = (r.returncode == 0 and "rtt/feature.py" in files and "rtt/other.py" in files
              and run_count(g) == 2)  # stale → re-validate lockless → gate ran twice
        record("render-relevant collision: re-validate then land", ok,
               "rc=%d gate_runs=%d (want 2)" % (r.returncode, run_count(g)))
    finally:
        cleanup(repo, gate_dir, wt)


def main():
    print("== land self-test (interpreter: %s) ==" % PY)
    for fn in (t_happy, t_orthogonal_skip, t_orthogonal_collision, t_relevant_collision):
        try:
            fn()
        except Exception as e:  # noqa: BLE001
            record(fn.__name__, False, "EXCEPTION %r" % e)
    npass = sum(1 for _, ok in _results if ok)
    print("\n%d/%d scenarios passed" % (npass, len(_results)))
    return 0 if npass == len(_results) else 1


if __name__ == "__main__":
    sys.exit(main())
