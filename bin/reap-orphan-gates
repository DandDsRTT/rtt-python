#!/usr/bin/env python3
"""Sweep orphaned render-gate / land process trees that a killed run left behind.

WHY THIS EXISTS
===============
When a land or its render gate is killed — by the harness over-time backstop, a user
TaskStop, a timeout, or the OS OOM killer under memory pressure — the ``pytest`` child is
NOT cleaned up. It reparents to PID 1 and keeps running a full 171-page in-process render
suite (very CPU/RAM heavy). It is now invisible to the render-gate semaphore's accounting:
its ticket's PID is still ALIVE, so ``conftest._scan()`` (which reclaims only DEAD PIDs)
keeps counting it as a live slot. Over a session of stop/relaunch cycles these accumulate,
so "3 agents" becomes 10-17 concurrent heavy processes → load spike → more OOM kills → more
orphans: a self-feeding leak (observed: two orphaned land trees alive >10 min, loadavg 35 on
6 cores). See ``RESOURCE_GOVERNANCE_DIAGNOSIS.md``.

The launchers now run their gate child in a kill-on-exit process group (``bin/land`` and
``bin/with-merge-lock``), which cleans up the *graceful* kill (SIGTERM/exit). This sweeper is
the backstop for the *un-trappable* kill (SIGKILL / OOM): it finds the orphans those leave and
removes them, then clears their now-defunct render-gate tickets so a slot frees immediately.

WHAT COUNTS AS AN ORPHAN
========================
A process is reaped iff BOTH hold:

  * its parent is PID 1 (reparented — its launching shell/land is gone), AND
  * its command matches a gate run (``bin/land`` or a ``pytest`` invocation), and is NOT one
    of the things that are *legitimately* PPID-1 (the detached merge-lock holder daemon
    ``with-merge-lock __daemon``, this sweeper, the load helper).

PPID==1 is the load-bearing signal: a healthy gate always has a living launcher parent (the
``bin/land`` process, a wrapping ``bash -c``, or the interactive shell). Only an abandoned run
reparents to init. We then kill the whole *subtree* of each orphan root (an orphaned
``bin/land`` whose ``pytest`` child has not yet reparented is rooted at the land; the child is
swept with it). The merge-lock holder daemon is intentionally PPID-1 but never matches the gate
pattern, so it is never touched — abandoned holds are reclaimed by the lock's own backstops.

Pure stdlib, runs under any Python (system 3.9 launchers and the .venv 3.14 conftest call it).

Usage::

    bin/reap-orphan-gates             # reap; print what was reaped
    bin/reap-orphan-gates --dry-run   # report only, kill nothing
    bin/reap-orphan-gates --quiet     # reap; print nothing unless something was reaped
    bin/reap-orphan-gates --pattern REGEX   # override the gate match (used by the selftest)

Exit status: 0 always (best-effort cleanup; a sweep that finds nothing is success).
"""

import os
import re
import signal
import subprocess
import sys
import time

_RENDER_GATE_DIR = os.environ.get("RTT_RENDER_GATE_DIR", "/tmp/rtt-render-gate.d")

# A gate run: the landing wrapper or a pytest invocation. Excludes are applied separately so
# this stays a simple "is it gate work?" test.
_GATE_RE = re.compile(r"(?:\bbin/land\b|(?:^|\s)-m\s+pytest\b|/pytest\b|\bpytest\b)")
# Never reap these even at PPID 1: the detached holder daemon is PPID-1 BY DESIGN (its lock is
# governed by with-merge-lock's own lease/abandon/abs-cap backstops, not by us), and our own
# helpers must not reap themselves.
_EXCLUDE_RE = re.compile(r"with-merge-lock|reap-orphan-gates|gate-load|governance-selftest")


def _log(msg):
    sys.stderr.write("[reap] %s\n" % msg)
    sys.stderr.flush()


def _snapshot():
    """List live processes as ``[(pid, ppid, command), ...]`` via ``ps``. Empty on failure."""
    try:
        r = subprocess.run(
            ["ps", "-axww", "-o", "pid=,ppid=,command="],
            capture_output=True, text=True, timeout=20,
        )
    except (OSError, subprocess.SubprocessError):
        return []
    if r.returncode != 0:
        return []
    procs = []
    for line in r.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        parts = line.split(None, 2)
        if len(parts) < 3:
            continue
        try:
            pid, ppid = int(parts[0]), int(parts[1])
        except ValueError:
            continue
        procs.append((pid, ppid, parts[2]))
    return procs


def _orphan_roots(procs, gate_re, exclude_re):
    """PIDs that are PPID-1, match the gate pattern, are not excluded, and are not us."""
    me = os.getpid()
    roots = []
    for pid, ppid, cmd in procs:
        if ppid != 1 or pid == me:
            continue
        if exclude_re.search(cmd):
            continue
        if gate_re.search(cmd):
            roots.append(pid)
    return roots


def _subtree(roots, procs):
    """All PIDs in the process subtrees rooted at `roots` (roots included)."""
    children = {}
    for pid, ppid, _cmd in procs:
        children.setdefault(ppid, []).append(pid)
    seen = set()
    stack = list(roots)
    while stack:
        pid = stack.pop()
        if pid in seen:
            continue
        seen.add(pid)
        stack.extend(children.get(pid, ()))
    return seen


def _kill(pids):
    """SIGTERM the whole set, give it a moment, then SIGKILL whatever survives."""
    for pid in pids:
        try:
            os.kill(pid, signal.SIGTERM)
        except OSError:
            pass
    deadline = time.time() + 1.0
    while time.time() < deadline:
        if not any(_alive(p) for p in pids):
            break
        time.sleep(0.1)
    for pid in pids:
        if _alive(pid):
            try:
                os.kill(pid, signal.SIGKILL)
            except OSError:
                pass


def _alive(pid):
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def _clear_render_tickets(pids):
    """Remove the render-gate ticket and heartbeat of each reaped PID, so a slot frees at
    once instead of waiting for the next `_scan`. Best-effort; missing files are fine."""
    try:
        names = os.listdir(_RENDER_GATE_DIR)
    except OSError:
        return
    suffixes = tuple("-%d" % p for p in pids)
    for name in names:
        base = name[4:] if name.startswith(".hb-") else name
        if base.endswith(suffixes):
            try:
                os.remove(os.path.join(_RENDER_GATE_DIR, name))
            except OSError:
                pass


def reap(dry_run=False, gate_re=_GATE_RE, exclude_re=_EXCLUDE_RE):
    """Find and (unless dry_run) kill orphaned gate trees. Returns the list of reaped PIDs."""
    procs = _snapshot()
    roots = _orphan_roots(procs, gate_re, exclude_re)
    if not roots:
        return []
    victims = sorted(_subtree(roots, procs))
    if dry_run:
        return victims
    _kill(victims)
    _clear_render_tickets(victims)
    return victims


def main(argv):
    # Hermetic-test / opt-out escape hatch: when set, the sweep is a no-op. The governance
    # selftest sets it for the bin/land startup reap so the test never touches real machine
    # orphans; a human can also set it to disable auto-reaping entirely.
    if os.environ.get("RTT_REAP_DISABLE") == "1":
        return 0
    dry_run = False
    quiet = False
    gate_re = _GATE_RE
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--dry-run":
            dry_run = True
        elif a == "--quiet":
            quiet = True
        elif a == "--pattern":
            i += 1
            try:
                gate_re = re.compile(argv[i])
            except (IndexError, re.error) as e:
                _log("bad --pattern: %s" % e)
                return 0
        else:
            _log("unknown arg %r" % a)
            return 0
        i += 1

    victims = reap(dry_run=dry_run, gate_re=gate_re)
    if victims:
        verb = "would reap" if dry_run else "reaped"
        _log("%s %d orphaned gate process(es): %s"
             % (verb, len(victims), " ".join(str(p) for p in victims)))
    elif not quiet:
        _log("no orphaned gate processes found")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
